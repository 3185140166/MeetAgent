# Algorithm Lab optional local environment.
# Copy this file to algorithm_lab/.env for local experiments.
# Do not put real secrets in this example file.

# The lab reuses the project root .env by default. Set this only when you want
# experiments to point to a different database.
ALGORITHM_LAB_DB_PATH=data/meetagent.db

# Default retrieval eval settings. Runner CLI args still take precedence.
ALGORITHM_LAB_DEFAULT_DATASET=algorithm_lab/datasets/meeting_retrieval_eval.example.jsonl
ALGORITHM_LAB_DEFAULT_BASELINES=bm25,multi_query_bm25
ALGORITHM_LAB_TOP_K_VALUES=3,5,8,10,20
ALGORITHM_LAB_CANDIDATE_K_VALUES=20,50

# Optional dense retrieval / rerank settings for future experiments.
# Keep API keys in the project root .env or your private algorithm_lab/.env.
ALGORITHM_LAB_ENABLE_DENSE=false
ALGORITHM_LAB_ENABLE_RERANK=false
ALGORITHM_LAB_EMBEDDING_PROVIDER=local
ALGORITHM_LAB_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
ALGORITHM_LAB_RERANK_PROVIDER=local
ALGORITHM_LAB_RERANK_MODEL=
