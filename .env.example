# ===== 大模型（问答 + 结构化抽取）=====
# 兼容 OpenAI 格式的 chat completions 接口均可使用
# 例如：https://api.openai.com/v1/chat/completions
#       https://api.deepseek.com/v1/chat/completions
#       或其他兼容接口
APIFUSION_API_URL=https://api.openai.com/v1/chat/completions
APIFUSION_API_KEY=your_api_key_here
APIFUSION_MODEL=gpt-4o

# ===== 数据库 =====
DB_PATH=data/meetagent.db

# ===== 问答检索 =====
TOP_K=8
# 默认关闭混合检索，避免本地 embedding 模型未就绪时自动连接 Hugging Face。
# 模型完整下载并构建 data/chroma 后可改为 true。
ENABLE_HYBRID_SEARCH=false

# ===== 结构化抽取 =====
EXTRACT_WINDOW_CHARS=6000
EXTRACT_CONCURRENCY=5

# ===== Embedding 方案（二选一）=====

# 方案 A：本地模型（默认，CPU 可跑，无 API 费用）
EMBED_PROVIDER=local
EMBED_LOCAL_MODEL=models/BAAI/bge-small-zh-v1.5   # 本地模型目录，约 90MB，512 维
EMBED_MODEL_DIR=models                            # cache_folder；仅在使用 HuggingFace 模型名时作为缓存目录
EMBED_DIM=512

# 方案 B：DashScope API（注释掉方案 A，取消下方注释）
# EMBED_PROVIDER=dashscope
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=your_dashscope_key_here
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
# EMBED_DIM=1024

# ===== 联网搜索（Tavily，可选）=====
# 填入后 Agent 可调用 web_search 查询会议库之外的外部信息
TAVILY_API_KEY=your_tavily_key_here
TAVILY_API_URL=https://api.tavily.com/search
WEB_SEARCH_MAX_RESULTS=5
WEB_SEARCH_DEFAULT_TOPIC=general        # general / news
WEB_SEARCH_DEFAULT_TIME_RANGE=          # day / week / month / year，留空表示不过滤时间

# ===== Session Memory（长会话摘要压缩）=====
SESSION_SUMMARY_ENABLED=true
SESSION_SUMMARY_TRIGGER_MESSAGES=12
SESSION_SUMMARY_RECENT_MESSAGES=6
SESSION_SUMMARY_MAX_CHARS=1800

# ===== Long-term Memory（阶段三：对话结束后抽取，默认关闭）=====
MEMORY_EXTRACTION_ENABLED=false
MEMORY_EXTRACTION_MAX_MEMORIES=5
MEMORY_EXTRACTION_MIN_CONFIDENCE=0.65

# ===== Long-term Memory（阶段五：检索注入，默认关闭）=====
MEMORY_RETRIEVAL_ENABLED=false
MEMORY_RETRIEVAL_TOP_K=5
